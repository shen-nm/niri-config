// Core System Integrations
prefer-no-csd
hotkey-overlay { skip-at-startup; }
screenshot-path "~/Pictures/Screenshots/Screenshot from %Y-%m-%d %H-%M-%S.png"
animations { }

// Component Modules Import Loop
include "inputs.kdl"
include "outputs.kdl"
include "layout.kdl"
include "window-rules.kdl"
include "startup.kdl"
include "binds.kdl"
include "cursor.kdl"
include "noctalia.kdl"
